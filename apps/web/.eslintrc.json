{
  "extends": [
    "next/core-web-vitals",
    "next/typescript",
    "prettier"
  ],
  "rules": {
    // Interdire les imports non typés
    "@typescript-eslint/no-explicit-any": "error",
    "@typescript-eslint/consistent-type-imports": ["error", { "prefer": "type-imports" }],
    // Interdire les console.log en dehors du debug (utiliser un logger)
    "no-console": ["warn", { "allow": ["warn", "error"] }],
    // Importer React pas nécessaire avec Next.js 15
    "react/react-in-jsx-scope": "off",
    // Composants avec displayName pour le debugging
    "react/display-name": "warn"
  }
}
