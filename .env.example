# =============================================================================
# France de Macron — Variables d'environnement
# Copier ce fichier vers apps/web/.env.local et renseigner les valeurs
# =============================================================================

# --- Supabase ---
# URL publique du projet Supabase (safe côté client)
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co

# Clé anonyme Supabase (safe côté client — RLS en place)
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ⚠️ CLEF SERVICE ROLE — JAMAIS exposée côté client (pas de NEXT_PUBLIC_)
# Uniquement dans les Server Actions / Route Handlers
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# --- Application ---
# URL publique de l'application (utilisée pour les OG images, etc.)
NEXT_PUBLIC_APP_URL=http://localhost:3040

# Environnement (development | production)
NODE_ENV=development

# --- Pipeline de données (scripts uniquement) ---
# Source officielle carburants
FUEL_API_BASE_URL=https://donnees.roulez-eco.fr/opendata

# Timeout en ms pour les requêtes vers l'API carburants
FUEL_API_TIMEOUT_MS=30000

# --- Newsletter (à configurer en v2) ---
# RESEND_API_KEY=re_...
# NEWSLETTER_FROM_EMAIL=newsletter@france-de-macron.fr

# --- Feature flags (optionnel) ---
# NEXT_PUBLIC_FEATURE_VOTE=true
# NEXT_PUBLIC_FEATURE_NEWSLETTER=true
