{
  "name": "france-de-macron",
  "version": "0.1.0",
  "private": true,
  "description": "Dashboard satirique & data-driven — French Cooked Index™",
  "scripts": {
    "dev": "pnpm --filter web dev",
    "build": "pnpm --filter web build",
    "start": "pnpm --filter web start",
    "lint": "pnpm --filter web lint",
    "typecheck": "pnpm --filter web typecheck",
    "typecheck:scripts": "pnpm exec tsc --noEmit -p scripts",
    "format": "prettier --write \"**/*.{ts,tsx,md,json}\" --ignore-path .gitignore",
    "format:check": "prettier --check \"**/*.{ts,tsx,md,json}\" --ignore-path .gitignore",
    "validate": "pnpm run typecheck && pnpm run typecheck:scripts && pnpm run lint && pnpm run format:check",
    "db:push": "pnpm dlx supabase@latest db push",
    "db:push:local": "pnpm dlx supabase@latest db push --local",
    "db:start": "pnpm dlx supabase@latest start --ignore-health-check",
    "db:types": "pnpm dlx supabase@latest gen types typescript --local > apps/web/src/lib/supabase/database.types.ts.tmp && mv apps/web/src/lib/supabase/database.types.ts.tmp apps/web/src/lib/supabase/database.types.ts",
    "db:types:linked": "pnpm dlx supabase@latest gen types typescript --linked > apps/web/src/lib/supabase/database.types.ts.tmp && mv apps/web/src/lib/supabase/database.types.ts.tmp apps/web/src/lib/supabase/database.types.ts",
    "fuel:backfill": "pnpm --filter scripts fuel:backfill",
    "fuel:backfill:annees": "pnpm --filter scripts fuel:backfill:annees",
    "fuel:backfill:last": "pnpm --filter scripts fuel:backfill:last",
    "fuel:daily": "pnpm --filter scripts fuel:daily",
    "fci:backfill": "pnpm --filter scripts fci:backfill",
    "insee:ipc:food:backfill": "pnpm --filter scripts insee:ipc:food:backfill",
    "eurostat:youth:backfill": "pnpm --filter scripts eurostat:youth:backfill",
    "electricity:trve:backfill": "pnpm --filter scripts electricity:trve:backfill",
    "deploy:check-vercel": "pnpm --filter scripts deploy:check-vercel",
    "deploy:preflight": "pnpm --filter scripts deploy:preflight",
    "deploy:verify-production": "pnpm --filter scripts deploy:verify-production",
    "deploy:verify-cron": "pnpm --filter scripts deploy:verify-cron",
    "deploy:verify": "pnpm --filter scripts deploy:verify",
    "qa:smoke": "pnpm --filter scripts qa:smoke",
    "qa:reduced-motion": "pnpm --filter scripts qa:reduced-motion",
    "qa:security-headers": "pnpm --filter scripts qa:security-headers",
    "qa:meta-descriptions": "pnpm --filter scripts qa:meta-descriptions",
    "qa:lighthouse-cwv": "pnpm --filter scripts seo:lighthouse",
    "seo:lighthouse": "pnpm --filter scripts seo:lighthouse",
    "qa:fci-intuition": "pnpm --filter scripts qa:fci-intuition",
    "qa:phase7": "pnpm run qa:reduced-motion && pnpm run qa:smoke && pnpm run qa:security-headers && pnpm run qa:meta-descriptions && pnpm run qa:lighthouse-cwv"
  },
  "devDependencies": {
    "prettier": "^3.3.3",
    "prettier-plugin-tailwindcss": "^0.6.14",
    "supabase": "^2.76.0",
    "typescript": "^5.5.4"
  },
  "engines": {
    "node": ">=20",
    "pnpm": ">=10"
  },
  "packageManager": "pnpm@10.30.3"
}
